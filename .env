##########################################
#                INFO                    #
##########################################

# === CONFIGURAZIONE PROXY IPTV ===

# ➤ Se usi TVProxy (solo con LISTA=lista):
# Esempio:
#   PROXYIP=http://<IP_SERVER>/proxy/m3u?url=
#
#   Sostituisci:
#   - <IP_SERVER> con l'indirizzo del tuo server/dispositivo.
#
#   ➜ Se utilizzi Termux usa l’IP locale del dispositivo (es. 192.168.x.x).
#   ➜ In alternativa, lascia vuoto e usa direttamente nel player IPTV:
#     http://<IP_SERVER>/proxy?url=<URL_LISTA_M3U>
#
#   Sostituisci:
#   - <IP_SERVER> con l'indirizzo del tuo server/dispositivo.
#   - <URL_LISTA_M3U> con l’URL raw della lista M3U.

# ➤ Se usi MediaFlow Proxy con LISTA=lista:
# Esempio:
#   PROXYIP=http://<IP_SERVER>/proxy/hls/manifest.m3u8?api_password=<PASSWORD>&d=
#
#   Sostituisci:
#   - <IP_SERVER> con l'indirizzo del tuo server/dispositivo.
#   - <PASSWORD> con l'api_password del mediaflow-proxy.
#
# Oppure lascia tutto vuoto ed usa direttamente nel player IPTV:
#     https://nzo66-mfpform3u.hf.space/proxy?<server-ip>:<password>?url=<url-lista>
#
#   🔁 Sostituisci:
#   - <server-ip> → con l’indirizzo IP o dominio del tuo MediaFlow Proxy
#   - <password>  → con la tua password API di MediaFlow Proxy
#   - <url-lista> → con l’URL raw della lista M3U

# ➤ Se usi MediaFlow Proxy con LISTA=listaMFP (consigliato per MFP):
# Inserisci i tuoi dati qui sotto:
#   IPMFP=<indirizzo-ip/url>
#   PASSMFP=<api_password>
#
#   Sostituisci:
#   - <IPMFP> con l'indirizzo del tuo server/dispositivo.
#   - <PASSMFP> con l'api_password del mediaflow-proxy.
#
# Oppure lascia tutto vuoto ed usa direttamente nel player IPTV:
#   https://nzo66-mfpform3u.hf.space/proxy?<server-ip>:<password>?url=<url-lista>
#
#   🔁 Sostituisci:
#   - <server-ip> → con l’indirizzo IP o dominio del tuo MediaFlow Proxy
#   - <password>  → con la tua password API di MediaFlow Proxy
#   - <url-lista> → con l’URL raw della lista M3U

# 📌 Differenze tra lista e listaMFP:
#   - `lista` → usa link .m3u8
#   - `listaMFP` → usa link .php di Daddy (più stabile con MFP)

##########################################
#         CONFIGURAZIONE LISTA           #
##########################################

# "lista" per TVProxy, "listaMFP" per MediaFlow Proxy
LISTA=lista

##########################################
#         CONFIGURAZIONE PROXY           #
##########################################

# Lascia vuoto per usare direttamente il proxy nel player IPTV
#PROXYIP=https://nzo66-tvproxy.hf.space/proxy/m3u?url=
PROXYIP=

# Dati per MediaFlow Proxy (usati solo con LISTA=listaMFP)
IPMFP=
PASSMFP=

##########################################
#         CONFIGURAZIONE GITHUB          #
##########################################

# ➤ Repository GitHub personale
NOMEGITHUB=nzv8
NOMEREPO=vts

##########################################
#        LINK DEI VARI SITI              #
##########################################

# ➤ Link base (senza slash finale)
LINK_DADDY=https://daddylive.dad
LINK_SKYSTREAMING=https://skystreaming.yoga

##########################################
#          FILTRI AGGIUNTIVI             #
##########################################

# ➤ Includere canali WORLD? (si / no)
WORLD=si

# ➤ Includere eventi in lingua inglese? (si / no)
EVENTI_EN=si
